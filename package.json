{
  "name": "zaparoo-app",
  "private": true,
  "license": "Apache-2.0",
  "version": "1.10.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cross-env NODE_ENV=development vite",
    "build": "tsc --noEmit -p tsconfig.build.json && vite build && npx cap sync",
    "build:web": "tsc --noEmit -p tsconfig.build.json && vite build",
    "build:core": "tsc --noEmit -p tsconfig.build.json && vite build --mode core",
    "sync": "npx cap sync",
    "build:server": "tsc --noEmit -p tsconfig.build.json && vite build && cross-env NODE_ENV=development cap sync",
    "build:analyze": "tsc --noEmit -p tsconfig.build.json && vite build --mode analyze",
    "live-update": "npm run build:web && npx capawesome apps:liveupdates:upload --app-id e96c260c-3271-4895-bff0-de9f8ca4d05a --path dist --private-key live-update-private.pem --channel production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
